#=============================================================================
# Makefile —— TicTacToeWin（井字棋游戏）
# 编译器：MinGW-w64 GCC（Windows）
# 图形库：GameLib（基于 Win32 GDI 的单头文件游戏库）
#=============================================================================

#-----------------------------------------------------------------------------
# 编译器与链接器设置
#-----------------------------------------------------------------------------
CXX      := g++
CXXFLAGS := -std=c++14 -O2 -Wall
LDFLAGS  := -mwindows

#-----------------------------------------------------------------------------
# 目录结构
#   src/    —— 源代码文件
#   lib/    —— 第三方库头文件
#   build/  —— 编译中间产物
#   output/ —— 最终可执行文件
#-----------------------------------------------------------------------------
SRCDIR   := src
BUILDDIR := build
OUTDIR   := output
TARGET   := $(OUTDIR)/main.exe

#-----------------------------------------------------------------------------
# 源文件与目标文件自动收集
#-----------------------------------------------------------------------------
SRCS      := $(wildcard $(SRCDIR)/*.cpp) main.cpp
OBJS      := $(SRCS:$(SRCDIR)/%.cpp=$(BUILDDIR)/%.o)
OBJS      := $(OBJS:main.cpp=$(BUILDDIR)/main.o)

#-----------------------------------------------------------------------------
# 伪目标
#-----------------------------------------------------------------------------
.PHONY: all clean run

all: $(TARGET)

#-----------------------------------------------------------------------------
# 链接
#-----------------------------------------------------------------------------
$(TARGET): $(OBJS) | $(OUTDIR)
	$(CXX) $^ -o $@ $(LDFLAGS)

#-----------------------------------------------------------------------------
# 编译 src/ 目录下的 .cpp
#-----------------------------------------------------------------------------
$(BUILDDIR)/%.o: $(SRCDIR)/%.cpp | $(BUILDDIR)
	$(CXX) $(CXXFLAGS) -I. -c $< -o $@

#-----------------------------------------------------------------------------
# 编译根目录下的 .cpp
#-----------------------------------------------------------------------------
$(BUILDDIR)/main.o: main.cpp | $(BUILDDIR)
	$(CXX) $(CXXFLAGS) -I. -c $< -o $@

#-----------------------------------------------------------------------------
# 创建目录
#-----------------------------------------------------------------------------
$(BUILDDIR):
	mkdir -p $(BUILDDIR)

$(OUTDIR):
	mkdir -p $(OUTDIR)

#-----------------------------------------------------------------------------
# 清理
#-----------------------------------------------------------------------------
clean:
	rm -f $(OBJS) $(TARGET)
	rm -rf $(BUILDDIR)
	rm -rf $(OUTDIR)

#-----------------------------------------------------------------------------
# 编译并运行
#-----------------------------------------------------------------------------
run: $(TARGET)
	$(TARGET)